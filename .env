# Version Configuration
CUDA_VERSION=12.8
NVM_VERSION=0.40.1
MINICONDA_VERSION=latest
STARSHIP_VERSION=latest
NODE_VERSION=lts

# System Configuration
MIN_DISK_SPACE_GB=2
MIN_UBUNTU_VERSION=20.04
CACHE_RETENTION_DAYS=7

# Download URLs (for caching)
NVM_INSTALL_URL=https://raw.githubusercontent.com/nvm-sh/nvm/v${NVM_VERSION}/install.sh
MINICONDA_URL=https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh
STARSHIP_INSTALL_URL=https://starship.rs/install.sh
OLLAMA_INSTALL_URL=https://ollama.ai/install.sh
TASK_INSTALL_URL=https://taskfile.dev/install.sh

# Paths
CACHE_DIR=${HOME}/.cache/dotfiles
BACKUP_DIR=${HOME}/.cache/dotfiles/backup
CONFIG_DIR=${HOME}/.config/dotfiles-local
