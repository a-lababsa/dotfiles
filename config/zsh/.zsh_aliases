# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# Modern CLI replacements
alias cat='bat'                    # Syntax highlighting
alias ls='eza'                     # Modern ls with Git status
alias ll='eza -la --git'           # Detailed list with Git info
alias l='eza -la --git --header'   # With header
alias tree='eza --tree'            # Tree view
alias find='fd'                    # Fast find alternative
alias grep='rg'                    # Ripgrep for fast search
alias man='tldr'                   # Concise documentation

# System
alias update='sudo apt update && sudo apt upgrade -y'
alias cleanup='sudo apt autoremove -y && sudo apt clean'
alias ports='sudo lsof -i -P -n | grep LISTEN'

# Git shortcuts
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'
alias gcm='git checkout main'
alias gcd='git checkout develop'

# Docker
alias dps='docker ps'
alias dimg='docker images'
alias dc='docker-compose'

# Development
alias py='python3'
alias pip='pip3'
alias npmls='npm list -g --depth=0'
alias nrun='npm run'
alias serve='python3 -m http.server'

# WSL specific
alias explorer='explorer.exe'
alias clip='clip.exe'
alias notepad='notepad.exe'
alias cmd='cmd.exe /c'
alias pwsh='powershell.exe'

# Directory shortcuts
alias dev='cd ~/workspace'
alias docs='cd ~/Documents'

# Fallbacks for compatibility
alias oldcat='command cat'         # Original cat command
alias oldls='command ls'           # Original ls command
alias oldfind='command find'       # Original find command
alias oldgrep='command grep'       # Original grep command
alias oldman='command man'         # Original man command

# Utility shortcuts
alias reload='source ~/.zshrc'     # Reload shell config
alias path='echo -e ${PATH//:/\\n}' # Display PATH nicely
